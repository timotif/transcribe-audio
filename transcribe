#!/bin/bash
# Wrapper script for transcribe.py
#
# INSTALLATION: Symlink this file into a directory on your PATH so that the
# script can always resolve back to transcribe.py in the repo. Do NOT copy it.
#
#   ln -s /path/to/repo/transcribe ~/.local/bin/transcribe
#
# Copying breaks the location-detection logic below.

# Resolve symlinks to find the real location of this script
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    SOURCE="$(readlink "$SOURCE")"
done
SCRIPT_DIR="$( cd "$( dirname "$SOURCE" )" && pwd )"

python "$SCRIPT_DIR/transcribe.py" "$@"
